{{ 'component-collection-subcategories.css' | asset_url | stylesheet_tag }}

<section class="collection-subcategories">
  <div class="collection-subcategories__container">

    {% if collection.title != blank %}
      <h1 class="collection-subcategories__main-title">
        {{ collection.title }}
      </h1>
    {% endif %}

    {% if collection.description != blank %}
      <div class="collection-subcategories__description">
        {{ collection.description }}
      </div>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="collection-subcategories__heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="collection-subcategories__grid">
      {% for block in section.blocks %}
        {% assign sub_collection = block.settings.collection %}

        <a
          href="{% if sub_collection != blank %}{{ sub_collection.url }}{% else %}#{% endif %}"
          class="collection-subcategories__card"
          {{ block.shopify_attributes }}
        >
          <h3 class="collection-subcategories__title">
            {% if block.settings.title != blank %}
              {{ block.settings.title }}
            {% elsif sub_collection != blank %}
              {{ sub_collection.title }}
            {% else %}
              קטגוריה
            {% endif %}
          </h3>
        </a>
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "תתי קטגוריות",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "כותרת",
      "default": "קטגוריות"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "קטגוריה",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "שם הקטגוריה"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "קישור לקולקציה"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "תתי קטגוריות"
    }
  ]
}
{% endschema %}