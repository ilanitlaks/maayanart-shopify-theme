{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'section-featured-collections-tabs.css' | asset_url | stylesheet_tag }}

<section class="home-products-tabs page-width">
  <div class="home-products-tabs__nav">
    <button class="home-products-tabs__btn active" type="button" data-tab="new"><span class="tab-heart">❤</span> חדש</button>
    <button class="home-products-tabs__btn" type="button" data-tab="loved"><span class="tab-heart">❤</span> אהבנו</button>
    <button class="home-products-tabs__btn" type="button" data-tab="deal"><span class="tab-heart">❤</span> דיל</button>
  </div>

  {% assign tabs = 'new,loved,deal' | split: ',' %}

  {% for tab in tabs %}
    {% assign collection_setting = 'collection_' | append: tab %}
    {% assign current_collection = section.settings[collection_setting] %}

    <div class="home-products-tabs__panel {% if forloop.first %}active{% endif %}" data-panel="{{ tab }}">
      <div class="home-products-tabs__slider-wrap">
        
          <button class="home-products-tabs__arrow home-products-tabs__arrow--prev" type="button" aria-label="קודם">
            <img 
              src="{{ 'arrow-right.png' | asset_url }}" 
              alt="חץ ימינה"
              width="65"
              height="32"
              loading="lazy"
            >
          </button>

        <ul class="home-products-tabs__slider" role="list">
          {% for product in current_collection.products %}
            <li class="home-products-tabs__slide">
              {% render 'card-product',
                card_product: product,
                media_aspect_ratio: 'adapt',
                image_shape: 'default',
                show_secondary_image: true,
                show_vendor: false,
                show_rating: false,
                lazy_load: true,
                quick_add: 'standard',
                section_id: section.id
              %}
            </li>
          {% endfor %}
        </ul>

        <button class="home-products-tabs__arrow home-products-tabs__arrow--next" type="button" aria-label="הבא">
          <img 
            src="{{ 'arrow-left.png' | asset_url }}" 
            alt="חץ שמאלה"
            width="65"
            height="32"
            loading="lazy"
          >
        </button>

      </div>
    </div>
  {% endfor %}
</section>


<script>
  document.querySelectorAll('.home-products-tabs').forEach(section => {
    const buttons = section.querySelectorAll('.home-products-tabs__btn');
    const panels = section.querySelectorAll('.home-products-tabs__panel');

    function updateArrows(panel) {
      const slider = panel.querySelector('.home-products-tabs__slider');
      const prev = panel.querySelector('.home-products-tabs__arrow--prev');
      const next = panel.querySelector('.home-products-tabs__arrow--next');

      if (!slider || !prev || !next) return;

      const maxScroll = slider.scrollWidth - slider.clientWidth;
      const current = Math.abs(slider.scrollLeft);
      const tolerance = 5;

      // RTL: בתחילת הרשימה הכל בצד ימין
      prev.classList.toggle('is-hidden', current <= tolerance);

      // בסוף הרשימה הכל בצד שמאל
      next.classList.toggle('is-hidden', current >= maxScroll - tolerance);

      // אם אין בכלל גלילה
      if (maxScroll <= tolerance) {
        prev.classList.add('is-hidden');
        next.classList.add('is-hidden');
      }
    }

    buttons.forEach(button => {
      button.addEventListener('click', () => {
        const tab = button.dataset.tab;

        buttons.forEach(btn => btn.classList.remove('active'));
        panels.forEach(panel => panel.classList.remove('active'));

        button.classList.add('active');

        const activePanel = section.querySelector(`[data-panel="${tab}"]`);
        activePanel.classList.add('active');

        setTimeout(() => updateArrows(activePanel), 50);
      });
    });

    panels.forEach(panel => {
      const slider = panel.querySelector('.home-products-tabs__slider');
      const prev = panel.querySelector('.home-products-tabs__arrow--prev');
      const next = panel.querySelector('.home-products-tabs__arrow--next');

      if (!slider || !prev || !next) return;

      next.addEventListener('click', () => {
        slider.scrollBy({ left: -300, behavior: 'smooth' });
      });

      prev.addEventListener('click', () => {
        slider.scrollBy({ left: 300, behavior: 'smooth' });
      });

      slider.addEventListener('scroll', () => updateArrows(panel));
      window.addEventListener('resize', () => updateArrows(panel));

      updateArrows(panel);
    });
  });
</script>

{% schema %}
{
  "name": "מוצרים בטאבים",
  "settings": [
    {
      "type": "collection",
      "id": "collection_new",
      "label": "קולקציית חדש"
    },
    {
      "type": "collection",
      "id": "collection_loved",
      "label": "קולקציית אהבנו"
    },
    {
      "type": "collection",
      "id": "collection_deal",
      "label": "קולקציית דיל"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "כמה מוצרים להציג"
    }
  ],
  "presets": [
    {
      "name": "מוצרים בטאבים"
    }
  ]
}
{% endschema %}