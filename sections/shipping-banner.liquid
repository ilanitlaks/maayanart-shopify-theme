{{ 'component-shipping-banner.css' | asset_url | stylesheet_tag }}

<section class="shipping-banner">
    <a href="{{ section.settings.link | default: '/pages/shipping' }}" class="shipping-banner__link">
    
    <div class="shipping-banner__inner">
      
      {% if section.settings.image != blank %}
        <img 
          src="{{ section.settings.image | image_url: width: 1600 }}" 
          alt="{{ section.settings.alt_text }}"
          class="shipping-banner__img"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
          loading="lazy"
        >
      {% endif %}

      <div class="shipping-banner__text">
        {{ section.settings.text }}
      </div>

    </div>

  </a>
</section>

{% schema %}
{
  "name": "Shipping banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "תמונה"
    },
    {
      "type": "text",
      "id": "text",
      "label": "טקסט",
      "default": "🚚 משלוחים לכל הארץ\nמשלוח חינם מעל ₪400"
    },
    {
      "type": "url",
      "id": "link",
      "label": "קישור",     
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Alt לתמונה",
      "default": "משלוחים מעיין היצירה"
    }
  ],
  "presets": [
    {
      "name": "Shipping banner"
    }
  ]
}
{% endschema %}