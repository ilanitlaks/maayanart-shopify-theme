{{ 'section-ideas-slider.css' | asset_url | stylesheet_tag }}

<section class="ideas-slider page-width">
  {% if section.settings.heading != blank %}
    <h2 class="ideas-slider__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="ideas-slider__track">
  {% assign active_tags = section.settings.active_tag | downcase | split: ',' %}

  {% for block in section.blocks %}
    {% assign block_tags = block.settings.tags | downcase %}
    {% assign show_idea = block.settings.show_idea %}
    {% assign should_show = false %}

    {% if section.settings.active_tag == blank %}
      {% assign should_show = true %}
    {% else %}
      {% for tag in active_tags %}
        {% assign clean_tag = tag | strip %}
        {% if block_tags contains clean_tag %}
          {% assign should_show = true %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {% if show_idea and should_show %}
      {% assign image_url = block.settings.image_url %}
      {% assign uploaded_image = block.settings.image %}

      {% if block.settings.link != blank %}
        <a class="ideas-slider__item" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
      {% else %}
        <div class="ideas-slider__item" {{ block.shopify_attributes }}>
      {% endif %}

        {% if image_url != blank %}
          <img
            src="{{ image_url }}"
            alt="{{ block.settings.alt | escape }}"
            loading="lazy"
          >
        {% elsif uploaded_image != blank %}
          <img
            src="{{ uploaded_image | image_url: width: 700 }}"
            alt="{{ block.settings.alt | escape }}"
            loading="lazy"
            width="{{ uploaded_image.width }}"
            height="{{ uploaded_image.height }}"
          >
        {% endif %}

      {% if block.settings.link != blank %}
        </a>
      {% else %}
      </div>
    {% endif %}
  {% endif %}
{% endfor %}
</section>

{% schema %}
{
  "name": "סליידר רעיונות",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "כותרת",
      "default": "קצת השראה ליצירה"
    },
    {
      "type": "text",
      "id": "active_tag",
      "label": "תג להצגה",
      "info": "למשל: פסח. אם ריק — יוצגו כל הרעיונות המסומנים"
    }
  ],
  "blocks": [
    {
      "type": "idea",
      "name": "רעיון",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "תמונה מהחנות"
        },
        {
          "type": "url",
          "id": "image_url",
          "label": "או קישור לתמונה מהבלוג"
        },
        {
          "type": "url",
          "id": "link",
          "label": "קישור לפוסט / מוצר / קולקציה"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "טקסט חלופי לתמונה",
          "default": "רעיון ליצירה"
        },
        {
          "type": "text",
          "id": "tags",
          "label": "תגיות",
          "info": "למשל: פסח, אביב, ילדים"
        },
        {
          "type": "checkbox",
          "id": "show_idea",
          "label": "להציג את הרעיון",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "סליידר רעיונות"
    }
  ]
}
{% endschema %}