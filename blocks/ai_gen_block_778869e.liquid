{% doc %}
  @prompt
    Create a smart collection display section for a collection page. The logic should be: if the collection has products, display them in a product grid as normal. If the collection has no products, automatically display its sub-collections (child collections) as clickable cards with their titles and images instead. This is for an Israeli craft supplies store (maayanart) where parent collections like "חומרי יצירה" (Craft Materials) contain sub-collections rather than direct products.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-smart-collection-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-smart-collection__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-smart-collection__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-smart-collection__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-smart-collection__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }

  .ai-smart-collection__card-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.card_background }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-smart-collection__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-smart-collection__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-smart-collection__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-smart-collection__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-smart-collection__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-smart-collection__info-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    text-align: {{ block.settings.card_text_alignment }};
  }

  .ai-smart-collection__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
    margin: 0 0 8px;
    color: {{ block.settings.card_title_color }};
  }

  .ai-smart-collection__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_price_size }}px;
    color: {{ block.settings.card_price_color }};
    margin: 0;
  }

  .ai-smart-collection__vendor-{{ ai_gen_id }} {
    font-size: 12px;
    color: #666;
    margin: 4px 0 0;
  }

  .ai-smart-collection__collection-count-{{ ai_gen_id }} {
    font-size: 14px;
    color: #666;
    margin: 4px 0 0;
  }

  .ai-smart-collection__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-smart-collection__empty-title-{{ ai_gen_id }} {
    font-size: 24px;
    margin: 0 0 12px;
  }

  .ai-smart-collection__empty-text-{{ ai_gen_id }} {
    font-size: 16px;
    margin: 0;
  }
{% endstyle %}

<smart-collection-display-{{ ai_gen_id }}
  class="ai-smart-collection-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-smart-collection__container-{{ ai_gen_id }}">
    {% if block.settings.show_heading and block.settings.heading != blank %}
      <h2 class="ai-smart-collection__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if collection.products.size > 0 %}
      <div class="ai-smart-collection__grid-{{ ai_gen_id }}">
        {% for product in collection.products limit: block.settings.products_limit %}
          <a
            href="{{ product.url }}"
            class="ai-smart-collection__card-{{ ai_gen_id }}"
          >
            <div class="ai-smart-collection__image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-smart-collection__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="600"
                >
              {% else %}
                <div class="ai-smart-collection__placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-smart-collection__info-{{ ai_gen_id }}">
              <h3 class="ai-smart-collection__title-{{ ai_gen_id }}">
                {{ product.title }}
              </h3>
              <p class="ai-smart-collection__price-{{ ai_gen_id }}">
                {{ product.price | money }}
              </p>
              {% if block.settings.show_vendor and product.vendor != blank %}
                <p class="ai-smart-collection__vendor-{{ ai_gen_id }}">
                  {{ product.vendor }}
                </p>
              {% endif %}
            </div>
          </a>
        {% endfor %}
      </div>

    {% else %}
      {% assign sub_collections = collections | where: 'metafields.custom.parent_collection', collection.handle %}
      
      {% if sub_collections.size > 0 %}
        <div class="ai-smart-collection__grid-{{ ai_gen_id }}">
          {% for sub_collection in sub_collections limit: block.settings.subcollections_limit %}
            <a
              href="{{ sub_collection.url }}"
              class="ai-smart-collection__card-{{ ai_gen_id }}"
            >
              <div class="ai-smart-collection__image-wrapper-{{ ai_gen_id }}">
                {% if sub_collection.featured_image %}
                  <img
                    src="{{ sub_collection.featured_image | image_url: width: 600 }}"
                    alt="{{ sub_collection.featured_image.alt | escape }}"
                    class="ai-smart-collection__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="600"
                  >
                {% elsif sub_collection.products.first.featured_image %}
                  <img
                    src="{{ sub_collection.products.first.featured_image | image_url: width: 600 }}"
                    alt="{{ sub_collection.products.first.featured_image.alt | escape }}"
                    class="ai-smart-collection__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="600"
                  >
                {% else %}
                  <div class="ai-smart-collection__placeholder-{{ ai_gen_id }}">
                    {{ 'collection-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              <div class="ai-smart-collection__info-{{ ai_gen_id }}">
                <h3 class="ai-smart-collection__title-{{ ai_gen_id }}">
                  {{ sub_collection.title }}
                </h3>
                {% if block.settings.show_product_count %}
                  <p class="ai-smart-collection__collection-count-{{ ai_gen_id }}">
                    {{ sub_collection.products_count }}
                    {% if sub_collection.products_count == 1 %}
                      {{ block.settings.product_count_singular }}
                    {% else %}
                      {{ block.settings.product_count_plural }}
                    {% endif %}
                  </p>
                {% endif %}
              </div>
            </a>
          {% endfor %}
        </div>
      {% else %}
        <div class="ai-smart-collection__empty-{{ ai_gen_id }}">
          <h3 class="ai-smart-collection__empty-title-{{ ai_gen_id }}">
            {{ block.settings.empty_heading }}
          </h3>
          <p class="ai-smart-collection__empty-text-{{ ai_gen_id }}">
            {{ block.settings.empty_text }}
          </p>
        </div>
      {% endif %}
    {% endif %}
  </div>
</smart-collection-display-{{ ai_gen_id }}>

<script>
  (function() {
    class SmartCollectionDisplay{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.init();
      }

      init() {
        const cards = this.querySelectorAll('.ai-smart-collection__card-{{ ai_gen_id }}');
        
        cards.forEach(card => {
          card.addEventListener('click', (e) => {
            const href = card.getAttribute('href');
            if (href && !e.ctrlKey && !e.metaKey) {
              e.preventDefault();
              window.location.href = href;
            }
          });
        });
      }
    }

    customElements.define('smart-collection-display-{{ ai_gen_id }}', SmartCollectionDisplay{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Smart collection display",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "מוצרים"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "right"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Heading spacing",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container width",
      "min": 800,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Maximum products to show",
      "min": 4,
      "max": 50,
      "step": 2,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "header",
      "content": "Sub-collections"
    },
    {
      "type": "range",
      "id": "subcollections_limit",
      "label": "Maximum sub-collections to show",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "text",
      "id": "product_count_singular",
      "label": "Product count text (singular)",
      "default": "מוצר"
    },
    {
      "type": "text",
      "id": "product_count_plural",
      "label": "Product count text (plural)",
      "default": "מוצרים"
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "card_text_alignment",
      "label": "Card text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "right"
    },
    {
      "type": "range",
      "id": "card_title_size",
      "label": "Card title size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card title color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "card_price_size",
      "label": "Card price size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "card_price_color",
      "label": "Card price color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Empty state"
    },
    {
      "type": "text",
      "id": "empty_heading",
      "label": "Empty heading",
      "default": "אין מוצרים או קטגוריות משנה"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty text",
      "default": "קטגוריה זו ריקה כרגע"
    }
  ],
  "presets": [
    {
      "name": "Smart collection display"
    }
  ]
}
{% endschema %}
